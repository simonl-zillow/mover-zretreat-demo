{
  "name": "mover-zretreat-demo",
  "private": true,
  "version": "0.0.1",
  "description": "Mover zRetreat demo — property search lib and app",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "server": "tsx watch server/index.ts",
    "dev:all": "concurrently \"npm run dev\" \"npm run server\"",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@types/express": "^5.0.6",
    "@types/node-fetch": "^2.6.13",
    "concurrently": "^9.2.1",
    "dotenv": "^17.4.0",
    "express": "^5.2.1",
    "node-fetch": "^3.3.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsx": "^4.21.0"
  },
  "devDependencies": {
    "@types/google.maps": "^3.58.1",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "typescript": "^5.8.3",
    "vite": "^6.0.0"
  }
}
