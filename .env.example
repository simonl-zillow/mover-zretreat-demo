# Workshop help: workshop-slides.html at repo root (participant guide + env tips)
#
# ── Copy to `.env.local` and adjust — do not commit secrets ───────────────────
# Client-visible flag (embedded in the built app). Use `mock` for offline teaching.
VITE_DATA_MODE=mock

# Live: Zillow-style home search/lookup via YOUR org’s proxy (never put this URL in React source).
# Vite forwards browser calls to /api/propertysearch → PROPERTY_SEARCH_PROXY_TARGET + PATH below.
# Only needed when VITE_DATA_MODE=live.
# Example host shape (placeholder): https://YOUR_PROJECT.supabase.co
PROPERTY_SEARCH_PROXY_TARGET=
# Path on that host to forward `/api/propertysearch` to (default matches this repo’s prior setup).
PROPERTY_SEARCH_PROXY_PATH=/functions/v1/xlab-propertysearch

# Optional: autocomplete experiments (lib/service/autocompleteService.ts). Public CDN default if unset.
# ZILLOW_AUTOCOMPLETE_PROXY_TARGET=https://www.zillowstatic.com

# ── Separate Express server (server/search.ts, server/home.ts) — NOT used by src/App.tsx ──
# If you run `npm run server`, set a base URL for that legacy search API.
# SEARCH_API_BASE_URL=
